Reject wrong-arch ELF objects and stop searching the android container paths

--- a/linker/linker.c
+++ b/linker/linker.c
@@ -747,8 +747,8 @@
 #define SOPATH_MAX 8
 
 static const char *apkenv_sopaths[SOPATH_MAX + 1] = {
-	"/vendor/lib",
-	"/system/lib",
+	/* /vendor/lib and /system/lib intentionally not searched: on hybris
+	 * devices they belong to the (32-bit) android container, not to us */
 	/* APKENV_PREFIX "/lib/" APKENV_TARGET "/bionic/", */
 #ifdef APKENV_LOCAL_BIONIC_PATH
 	APKENV_LOCAL_BIONIC_PATH,
@@ -927,12 +927,24 @@
 	if (hdr->e_ident[EI_MAG3] != ELFMAG3)
 		return -1;
 
-	/* TODO: make this proper for aarch64 / x86_64 */
-	/*#ifdef ANDROID_ARM_LINKER
-	    if (hdr->e_machine != EM_ARM) return -1;
-	#elif defined(ANDROID_X86_LINKER)
-	    if (hdr->e_machine != EM_386) return -1;
-	#endif*/
+	/* Reject wrong-class/wrong-machine objects: on Ubuntu Touch the Halium
+	 * android container is mounted at /system, and its 32-bit ARM libraries
+	 * would otherwise pass the magic check and crash us in the phdr walk. */
+	if (hdr->e_ident[EI_CLASS] != (sizeof(void *) == 8 ? ELFCLASS64 : ELFCLASS32)) {
+		DL_ERR("%s: wrong ELF class 0x%x", name, hdr->e_ident[EI_CLASS]);
+		return -1;
+	}
+#if defined(__aarch64__)
+	if (hdr->e_machine != EM_AARCH64) {
+		DL_ERR("%s: wrong ELF machine 0x%x", name, hdr->e_machine);
+		return -1;
+	}
+#elif defined(__x86_64__)
+	if (hdr->e_machine != EM_X86_64) {
+		DL_ERR("%s: wrong ELF machine 0x%x", name, hdr->e_machine);
+		return -1;
+	}
+#endif
 	return 0;
 }
 
